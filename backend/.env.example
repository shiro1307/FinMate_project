# FinMate Backend Environment Variables
# Copy this file to .env and fill in your values

# Database Configuration
# For SQLite (local development):
DATABASE_URL=sqlite:///./finmate.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost/finmate_db

# Gemini API Key (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Authentication
SECRET_KEY=your_super_secret_jwt_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email Configuration (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SENDER_EMAIL=noreply@finmate.app

# Optional: Plaid API (for bank integration)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# Optional: Sentry for error tracking
SENTRY_DSN=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Rate Limiting (requests per minute)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=1
